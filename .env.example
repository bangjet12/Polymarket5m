python3 - <<'PY'
from pathlib import Path

# ===== Patch DB: wallet_trades table + logger =====
db = Path("src/polymaking/storage/db.py")
s = db.read_text()

if "CREATE TABLE IF NOT EXISTS wallet_trades" not in s:
    s = s.replace(
'''        self.conn.commit()
''',
'''        cur.execute(
            """
            CREATE TABLE IF NOT EXISTS wallet_trades (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                ts TEXT NOT NULL,
                trade_id TEXT,
                market_id TEXT,
                question TEXT,
                wallet TEXT,
                outcome TEXT,
                side TEXT,
                price REAL,
                size REAL,
                usd_value REAL,
                raw TEXT
            )
            """
        )
        cur.execute("CREATE UNIQUE INDEX IF NOT EXISTS idx_wallet_trades_trade_id ON wallet_trades(trade_id)")
        cur.execute("CREATE INDEX IF NOT EXISTS idx_wallet_trades_wallet ON wallet_trades(wallet)")
        cur.execute("CREATE INDEX IF NOT EXISTS idx_wallet_trades_market ON wallet_trades(market_id)")
        self.conn.commit()
''',
        1
    )

if "def log_wallet_trades" not in s:
    s = s.replace(
'''    def summary(self) -> Dict[str, Any]:
''',
'''    def log_wallet_trades(self, market, trades: Iterable[Dict[str, Any]]) -> None:
        def f(value) -> float:
            try:
                return float(value or 0.0)
            except Exception:
                return 0.0

        now = datetime.utcnow().isoformat()
        rows = []

        for t in trades:
            wallet = str(
                t.get("user")
                or t.get("address")
                or t.get("maker")
                or t.get("trader")
                or ""
            ).lower()

            if not wallet:
                continue

            outcome = str(t.get("outcome") or t.get("asset") or t.get("token") or "")
            side = str(t.get("side") or t.get("type") or t.get("action") or "")
            price = f(t.get("price") or t.get("avgPrice"))
            size = f(t.get("size") or t.get("amount") or t.get("shares") or t.get("value"))
            usd_value = price * size if price and size else f(t.get("usd") or t.get("notional"))

            trade_id = str(
                t.get("id")
                or t.get("transactionHash")
                or t.get("transaction_hash")
                or t.get("hash")
                or f"{market.id}:{wallet}:{outcome}:{side}:{price}:{size}:{t.get('timestamp') or t.get('createdAt')}"
            )

            rows.append((
                now,
                trade_id,
                market.id,
                market.question,
                wallet,
                outcome,
                side,
                price,
                size,
                usd_value,
                json.dumps(t, ensure_ascii=False),
            ))

        if rows:
            self.conn.executemany(
                """
                INSERT OR IGNORE INTO wallet_trades
                (ts, trade_id, market_id, question, wallet, outcome, side, price, size, usd_value, raw)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
                """,
                rows,
            )
            self.conn.commit()

    def summary(self) -> Dict[str, Any]:
''',
        1
    )

db.write_text(s)

# ===== Patch main: simpan recent trades wallet setiap market diproses =====
main = Path("src/polymaking/main.py")
s = main.read_text()

old = '''    async def _wallet_bias(self, market: Market):
        # Lightweight per-market signal. For real 14k-wallet analysis, run a separate collector/backfill job.
        try:
            trades = await self.pm.get_trades(market_id=market.id, limit=50)
            return self.wallets.infer_market_bias(market.id, trades)
        except Exception:
            return 0.0, "wallet signal unavailable"
'''

new = '''    async def _wallet_bias(self, market: Market):
        # Wallet scan hanya untuk market yang sudah lolos filter _load_markets.
        # Kalau _load_markets kamu sudah Up/Down 5m BTC/ETH/XRP/SOL, maka wallet_trades juga hanya dari market itu.
        try:
            trades = await self.pm.get_trades(market_id=market.id, limit=100)
            self.store.log_wallet_trades(market, trades)
            return self.wallets.infer_market_bias(market.id, trades)
        except Exception:
            return 0.0, "wallet signal unavailable"
'''

if old in s:
    s = s.replace(old, new)
elif "self.store.log_wallet_trades(market, trades)" not in s:
    s = s.replace(
        "trades = await self.pm.get_trades(market_id=market.id, limit=50)\n            return self.wallets.infer_market_bias(market.id, trades)",
        "trades = await self.pm.get_trades(market_id=market.id, limit=100)\n            self.store.log_wallet_trades(market, trades)\n            return self.wallets.infer_market_bias(market.id, trades)"
    )

main.write_text(s)

print("OK: wallet scanner khusus market yang diproses bot sudah ditambahkan.")
PY
