# --- Wallet Configuration ---
PRIVATE_KEY=your_0xde642fde44c8a7b358e3fce032b2434eb7852007e520d2d688f8b1741569c693
WALLET_ADDRESS=0xA790Fa1294BD7409ab197f5aA2316107cD05A305

# --- Polymarket Endpoints ---
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# --- Spot Price Feeds ---
BINANCE_API_URL=https://api.binance.com/api/v3
COINBASE_API_URL=https://api.coinbase.com/v2

# --- Trading Strategy Parameters ---
# Minimum price divergence (%) to trigger a trade
MIN_DIVERGENCE_THRESHOLD=2.0
# Maximum divergence - avoid trading on stale/broken data
MAX_DIVERGENCE_THRESHOLD=15.0
# Trading interval in milliseconds (300000 = 5 minutes)
TRADING_INTERVAL_MS=300000
# Order type: LIMIT or MARKET
ORDER_TYPE=LIMIT
# Slippage tolerance for limit orders (%)
SLIPPAGE_TOLERANCE=0.5

# --- Risk Management ---
# Maximum position size in USDC per trade
MAX_POSITION_SIZE=3
# Maximum total exposure in USDC
MAX_TOTAL_EXPOSURE=1000
# Maximum number of open positions
MAX_OPEN_POSITIONS=5
# Daily loss limit in USDC (stops trading if hit)
DAILY_LOSS_LIMIT=200
# Minimum confidence score (0-1) to execute trade
MIN_CONFIDENCE=0.7

# --- Alerts & Notifications ---
# Telegram Bot Token (optional)
TELEGRAM_BOT_TOKEN=
# Telegram Chat ID (optional)
TELEGRAM_CHAT_ID=

# --- Logging ---
LOG_LEVEL=info
LOG_FILE=./logs/trader.log

# --- VPS / Deployment ---
# Node environment
NODE_ENV=production
